  "hgDogExerciseAlert": "Lack of exercise in dogs is not just a physical issue. It is a major cause of stress, anxiety, and destructive behavior.",
  "@hgDogExerciseAlert": {
    "description": "Health guide: Dog exercise alert"
  },
  "hgDogWalk1": "Small breeds: **20-30 mins**+ daily, Medium/Large breeds: **1 hour**+ recommended.",
  "@hgDogWalk1": {
    "description": "Health guide: Dog walk 1"
  },
  "hgDogWalk2": "Walks are not just for potty, but for **olfactory stimulation, socialization, and stress relief**.",
  "@hgDogWalk2": {
    "description": "Health guide: Dog walk 2"
  },
  "hgDogWalk3": "Allow plenty of sniffing — Very effective for relieving mental fatigue.",
  "@hgDogWalk3": {
    "description": "Health guide: Dog walk 3"
  },
  "hgDogWalk4": "Beware of asphalt burns in summer — Recommend walking before 7 AM or in the evening.",
  "@hgDogWalk4": {
    "description": "Health guide: Dog walk 4"
  },
  "hgDogPlay1": "**Fetch / Tug-of-war** — Releases physical energy, strengthens bond with owner.",
  "@hgDogPlay1": {
    "description": "Health guide: Dog play 1"
  },
  "hgDogPlay2": "**Nosework** — Brain stimulation, 15 mins equals 30 mins of walking effect.",
  "@hgDogPlay2": {
    "description": "Health guide: Dog play 2"
  },
  "hgDogPlay3": "**Puzzle/Kong toys** — Effective in alleviating separation anxiety when alone.",
  "@hgDogPlay3": {
    "description": "Health guide: Dog play 3"
  },
  "hgDogPlay4": "Just **10-15 mins** of focused play daily significantly reduces stress levels.",
  "@hgDogPlay4": {
    "description": "Health guide: Dog play 4"
  },
  "hgDogStress1": "Destroying furniture/objects, excessive barking — Signs of lack of exercise/stimulation.",
  "@hgDogStress1": {
    "description": "Health guide: Dog stress 1"
  },
  "hgDogStress2": "Tail chasing, excessive licking (paws, body) — Compulsive behavior, attempt to relieve stress.",
  "@hgDogStress2": {
    "description": "Health guide: Dog stress 2"
  },
  "hgDogStress3": "Excessive anxiety or potty mistakes when owner leaves — Suspected separation anxiety.",
  "@hgDogStress3": {
    "description": "Health guide: Dog stress 3"
  },
  "hgDogStress4": "If it persists, consulting a vet or pet behavior specialist is recommended.",
  "@hgDogStress4": {
    "description": "Health guide: Dog stress 4"
  },
  "hgDogSocial1": "**3-14 weeks** of age is the golden period for socialization — Exposure to various people, sounds, and environments is crucial.",
  "@hgDogSocial1": {
    "description": "Health guide: Dog social 1"
  },
  "hgDogSocial2": "Interaction with other dogs — Utilize dog parks or puppy classes.",
  "@hgDogSocial2": {
    "description": "Health guide: Dog social 2"
  },
  "hgDogSocial3": "Experiencing new places, smells, and sounds contributes to mental enrichment.",
  "@hgDogSocial3": {
    "description": "Health guide: Dog social 3"
  },
  "hgDogSocial4": "Positive reinforcement training (clicker, treats) increases brain stimulation and bonding simultaneously.",
  "@hgDogSocial4": {
    "description": "Health guide: Dog social 4"
  },
  "hgCatCoreFvrcp": "**FVRCP (Combo Vaccine)** — Herpesvirus, Calicivirus, Panleukopenia.\n1st dose at 6-8 weeks, 3 doses at 3-4 week intervals, then every 1-3 years.",
  "@hgCatCoreFvrcp": {
    "description": "Health guide: Cat FVRCP"
  },
  "hgCatCoreRabies": "**Rabies** — Mandatory for outdoor cats, recommended for indoor cats (Legally required in many areas).",
  "@hgCatCoreRabies": {
    "description": "Health guide: Cat Rabies"
  },
  "hgCatNonCoreFelv": "**Feline Leukemia (FeLV)** — Highly recommended for outdoor cats or multi-cat households.",
  "@hgCatNonCoreFelv": {
    "description": "Health guide: Cat FeLV"
  },
  "hgCatNonCoreChlamydia": "**Feline Chlamydia** — Multi-cat environments, prevents conjunctivitis.",
  "@hgCatNonCoreChlamydia": {
    "description": "Health guide: Cat Chlamydia"
  },
  "hgCatNonCoreFiv": "**Feline Immunodeficiency Virus (FIV)** — Outdoor male cats (transmitted through bite wounds).",
  "@hgCatNonCoreFiv": {
    "description": "Health guide: Cat FIV"
  },
  "hgCatExternalParasites1": "Outdoor cats: Administer flea/tick preventative **once a month**.",
  "@hgCatExternalParasites1": {
    "description": "Health guide: Cat External Parasites 1"
  },
  "hgCatExternalParasites2": "Indoor cats can also get fleas via human clothes/shoes → Preventative recommended **every 3 months**.",
  "@hgCatExternalParasites2": {
    "description": "Health guide: Cat External Parasites 2"
  },
  "hgCatExternalParasites3": "When using spot-on products, apply accurately to the back of the neck.",
  "@hgCatExternalParasites3": {
    "description": "Health guide: Cat External Parasites 3"
  },
  "hgCatInternalHeartworm": "Internal Parasites & Heartworm",
  "@hgCatInternalHeartworm": {
    "description": "Health guide: Cat Internal & Heartworm"
  },
  "hgCatInternalParasites1": "Roundworms/Tapeworms: Administer dewormer **every 3-6 months**.",
  "@hgCatInternalParasites1": {
    "description": "Health guide: Cat Internal Parasites 1"
  },
  "hgCatInternalParasites2": "If feeding a raw diet (raw meat/fish), more frequent testing is recommended.",
  "@hgCatInternalParasites2": {
    "description": "Health guide: Cat Internal Parasites 2"
  },
  "hgCatHeartworm1": "Heartworm — **There is no cure for cats, prevention is the only way**. Monthly administration highly recommended for outdoor cats.",
  "@hgCatHeartworm1": {
    "description": "Health guide: Cat Heartworm 1"
  },
  "hgCatMajorDiseases": "Beware of Major Cat Diseases",
  "@hgCatMajorDiseases": {
    "description": "Health guide: Cat major diseases section"
  },
  "hgCatDiseaseAlert": "Cats hide their pain, so when symptoms appear, the disease has often already progressed. Regular checkups are especially important.",
  "@hgCatDiseaseAlert": {
    "description": "Health guide: Cat disease alert"
  },
  "hgCatDiseaseFlutd": "**Feline Lower Urinary Tract Disease (FLUTD)** — Common in males. If unable to urinate, immediate emergency care is needed.",
  "@hgCatDiseaseFlutd": {
    "description": "Health guide: Cat FLUTD"
  },
  "hgCatDiseaseCkd": "**Chronic Kidney Disease (CKD)** — #1 cause of death in senior cats. Regular kidney panel tests essential for cats 7+ years old.",
  "@hgCatDiseaseCkd": {
    "description": "Health guide: Cat CKD"
  },
  "hgCatDiseaseDiabetes": "**Feline Diabetes** — Risk for obese/senior cats. Watch for increased thirst and urination.",
  "@hgCatDiseaseDiabetes": {
    "description": "Health guide: Cat Diabetes"
  },
  "hgCatDiseaseHyperthyroidism": "**Hyperthyroidism** — Common in cats 10+ years old. Symptoms include weight loss, overeating, and hyperactivity.",
  "@hgCatDiseaseHyperthyroidism": {
    "description": "Health guide: Cat Hyperthyroidism"
  },
  "hgCatDiseaseStomatitis": "**Stomatitis** — Very common in cats. Check if there is bad breath, drooling, or loss of appetite.",
  "@hgCatDiseaseStomatitis": {
    "description": "Health guide: Cat Stomatitis"
  },
  "hgCatDiseaseFhv": "**Feline Herpes (FHV-1)** — Once infected, it remains dormant for life. Relapses during stress, causing sneezing, eye discharge, conjunctivitis.",
  "@hgCatDiseaseFhv": {
    "description": "Health guide: Cat FHV"
