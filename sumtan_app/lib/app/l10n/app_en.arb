  "hgDogCoreDhppl": "**DHPPL (Combination Vaccine)** — Distemper, Hepatitis, Parvovirus, Parainfluenza, and Leptospirosis.\n1st dose at 6–8 weeks of age, 3 doses at 3–4 week intervals, then annual boosters",
  "@hgDogCoreDhppl": {
    "description": "Dog core vaccine description for DHPPL."
  },
  "hgDogCoreRabies": "**Rabies** — 1st dose after 3 months of age, then once annually (legally required vaccination)",
  "@hgDogCoreRabies": {
    "description": "Dog core vaccine description for rabies."
  },
  "hgDogCoreCorona": "**Coronavirus Enteritis** — Starts at 6–8 weeks of age, 2 doses at 3–4 week intervals, then annual boosters",
  "@hgDogCoreCorona": {
    "description": "Dog core vaccine description for coronavirus enteritis."
  },
  "hgDogNonCoreKennel": "**Kennel Cough** — Recommended for multi-dog environments, grooming salons, or boarding facilities. Available as intranasal or injectable type",
  "@hgDogNonCoreKennel": {
    "description": "Dog non-core vaccine description for kennel cough."
  },
  "hgDogNonCoreFlu": "**Canine Influenza** — Recommended for dogs with frequent outdoor activity or frequent contact with other dogs",
  "@hgDogNonCoreFlu": {
    "description": "Dog non-core vaccine description for influenza."
  },

  "hgDogHeartworm1": "Around mosquito season (March–November), monthly preventive medication is recommended",
  "@hgDogHeartworm1": {
    "description": "Dog heartworm prevention guidance item 1."
  },
  "hgDogHeartworm2": "Infection is difficult to treat and can be fatal — **prevention is the best protection**",
  "@hgDogHeartworm2": {
    "description": "Dog heartworm prevention guidance item 2."
  },
  "hgDogHeartworm3": "Before starting medication, testing is required to confirm a negative infection status",
  "@hgDogHeartworm3": {
    "description": "Dog heartworm prevention guidance item 3."
  },
  "hgDogHeartworm4": "Year-round prevention is safer and commonly recommended by veterinarians",
  "@hgDogHeartworm4": {
    "description": "Dog heartworm prevention guidance item 4."
  },
  "hgDogExternalParasites1": "Administer spot-on or oral preventives **monthly**",
  "@hgDogExternalParasites1": {
    "description": "Dog external parasite prevention guidance item 1."
  },
  "hgDogExternalParasites2": "After walks, always check the ears, between the toes, and armpits for ticks",
  "@hgDogExternalParasites2": {
    "description": "Dog external parasite prevention guidance item 2."
  },
  "hgDogExternalParasites3": "When removing a tick, use tweezers and pull slowly straight upward without twisting",
  "@hgDogExternalParasites3": {
    "description": "Dog external parasite prevention guidance item 3."
  },
  "hgDogInternalParasites1": "Roundworms, hookworms, and whipworms: administer dewormer **every 3–6 months**",
  "@hgDogInternalParasites1": {
    "description": "Dog internal parasite prevention guidance item 1."
  },
  "hgDogInternalParasites2": "For puppies from 2 weeks of age: deworm 4 times at 2-week intervals, then continue regular management",
  "@hgDogInternalParasites2": {
    "description": "Dog internal parasite prevention guidance item 2."
  },

  "hgDental1": "Daily brushing is ideal — at least **3 times per week** is recommended",
  "@hgDental1": {
    "description": "Dental care guidance item 1."
  },
  "hgDental2": "Always use **pet-specific toothpaste**. Do not use human toothpaste containing xylitol",
  "@hgDental2": {
    "description": "Dental care guidance item 2."
  },
  "hgDental3": "Severe tartar requires professional scaling at a veterinary clinic under general anesthesia",
  "@hgDental3": {
    "description": "Dental care guidance item 3."
  },
  "hgDental4": "Dental chews and dental toys can support oral care as supplementary tools",
  "@hgDental4": {
    "description": "Dental care guidance item 4."
  },

  "hgDogForbiddenFoodAlert": "The foods below are toxic to dogs. Even small amounts can be dangerous, so never feed them.",
  "@hgDogForbiddenFoodAlert": {
    "description": "Warning text for foods forbidden to dogs."
  },
  "hgDogForbiddenGrape": "**Grapes and raisins** — can cause kidney failure; even small amounts may be fatal",
  "@hgDogForbiddenGrape": {
    "description": "Dog forbidden food description for grapes and raisins."
  },
  "hgDogForbiddenChocolate": "**Chocolate and cacao** — theobromine poisoning, heart failure, and seizures",
  "@hgDogForbiddenChocolate": {
    "description": "Dog forbidden food description for chocolate and cacao."
  },
  "hgDogForbiddenOnion": "**Onions, garlic, and leeks** — destroy red blood cells and cause hemolytic anemia",
  "@hgDogForbiddenOnion": {
    "description": "Dog forbidden food description for onions, garlic, and leeks."
  },
  "hgDogForbiddenXylitol": "**Xylitol** — causes excessive insulin release, hypoglycemia, and liver failure",
  "@hgDogForbiddenXylitol": {
    "description": "Dog forbidden food description for xylitol."
  },
  "hgDogForbiddenMacadamia": "**Macadamia nuts** — muscle weakness, high fever, and vomiting",
  "@hgDogForbiddenMacadamia": {
    "description": "Dog forbidden food description for macadamia nuts."
  },
  "hgDogForbiddenDoughAlcohol": "**Raw dough and alcohol** — ethanol poisoning and hypoglycemia",
  "@hgDogForbiddenDoughAlcohol": {
    "description": "Dog forbidden food description for raw dough and alcohol."
  },
  "hgDogForbiddenAvocado": "**Avocado** — contains persin and may cause vomiting and diarrhea",
  "@hgDogForbiddenAvocado": {
    "description": "Dog forbidden food description for avocado."
  },

  "hgEmergencyAlert": "If any of the symptoms below appear, visit a veterinary clinic immediately.",
  "@hgEmergencyAlert": {
    "description": "Common emergency warning text for dog and cat guides."
  },
  "hgDogEmergency1": "Complete loss of appetite for more than 24 hours",
  "@hgDogEmergency1": {
    "description": "Dog emergency symptom item 1."
  },
  "hgDogEmergency2": "Vomiting or diarrhea repeated 3 or more times in one day",
  "@hgDogEmergency2": {
    "description": "Dog emergency symptom item 2."
  },
  "hgDogEmergency3": "Abdominal bloating and unproductive retching, possible gastric dilatation-volvulus",
  "@hgDogEmergency3": {
    "description": "Dog emergency symptom item 3."
  },
  "hgDogEmergency4": "Difficulty breathing, pale gums, or cyanosis",
  "@hgDogEmergency4": {
    "description": "Dog emergency symptom item 4."
  },
  "hgDogEmergency5": "Seizures, convulsions, or loss of consciousness",
  "@hgDogEmergency5": {
    "description": "Dog emergency symptom item 5."
  },
  "hgDogEmergency6": "No urination for more than 12 hours",
  "@hgDogEmergency6": {
    "description": "Dog emergency symptom item 6."
  },
  "hgDogEmergency7": "Visible trauma, fracture, or heavy bleeding",
  "@hgDogEmergency7": {
    "description": "Dog emergency symptom item 7."
  },

  "hgDogExerciseAlert": "For dogs, lack of exercise is not just a fitness issue. It can be a major cause of stress, anxiety, and destructive behavior.",
  "@hgDogExerciseAlert": {
    "description": "Alert text for dog exercise and mental health section."
  },
  "hgDogWalk1": "Small breeds: at least **20–30 minutes** daily; medium and large breeds: **1 hour or more** recommended",
  "@hgDogWalk1": {
    "description": "Dog walking guidance item 1."
  },
  "hgDogWalk2": "Walks are not only for elimination — they provide **scent stimulation, socialization, and stress relief**",
  "@hgDogWalk2": {
    "description": "Dog walking guidance item 2."
  },
  "hgDogWalk3": "Allow plenty of sniffing time — it is highly effective for relieving mental fatigue",
  "@hgDogWalk3": {
    "description": "Dog walking guidance item 3."
  },
  "hgDogWalk4": "In summer, beware of asphalt burns — walks before 7 a.m. or in the evening are recommended",
  "@hgDogWalk4": {
    "description": "Dog walking guidance item 4."
  },
  "hgDogPlay1": "**Fetch and tug-of-war** — help release physical energy and strengthen the bond with the owner",
  "@hgDogPlay1": {
    "description": "Dog play guidance item 1."
  },
  "hgDogPlay2": "**Nosework** — stimulates the brain and can provide an effect similar to a 30-minute walk in just 15 minutes",
  "@hgDogPlay2": {
    "description": "Dog play guidance item 2."
  },
  "hgDogPlay3": "**Puzzle toys and Kong toys** — help reduce separation anxiety during alone time",
  "@hgDogPlay3": {
    "description": "Dog play guidance item 3."
  },
  "hgDogPlay4": "Just **10–15 minutes** of focused play each day can significantly reduce stress",
  "@hgDogPlay4": {
    "description": "Dog play guidance item 4."
  },
  "hgDogStress1": "Destroying furniture or objects and excessive barking may signal lack of exercise or stimulation",
  "@hgDogStress1": {
    "description": "Dog stress signal item 1."
  },
  "hgDogStress2": "Tail biting or excessive licking of paws/body may indicate compulsive behavior or stress relief attempts",
  "@hgDogStress2": {
    "description": "Dog stress signal item 2."
  },
  "hgDogStress3": "Extreme anxiety when the owner leaves and potty accidents may suggest separation anxiety",
  "@hgDogStress3": {
    "description": "Dog stress signal item 3."
  },
  "hgDogStress4": "If symptoms persist, consult a veterinarian or animal behavior specialist",
  "@hgDogStress4": {
    "description": "Dog stress signal item 4."
  },
  "hgDogSocial1": "**3–14 weeks of age** is the golden period for socialization — exposure to various people, sounds, and environments is important",
  "@hgDogSocial1": {
    "description": "Dog socialization guidance item 1."
  },
  "hgDogSocial2": "Interaction with other dogs — dog parks and puppy classes can help",
  "@hgDogSocial2": {
    "description": "Dog socialization guidance item 2."
  },
  "hgDogSocial3": "Experiencing new places, smells, and sounds contributes to mental enrichment",
  "@hgDogSocial3": {
    "description": "Dog socialization guidance item 3."
  },
  "hgDogSocial4": "Positive reinforcement training, such as clickers and treats, stimulates the brain and strengthens bonding",
  "@hgDogSocial4": {
    "description": "Dog socialization guidance item 4."
  },

  "hgCatCoreFvrcp": "**FVRCP (Combination Vaccine)** — feline herpesvirus, calicivirus, and panleukopenia.\n1st dose at 6–8 weeks of age, 3 doses at 3–4 week intervals, then every 1–3 years",
  "@hgCatCoreFvrcp": {
    "description": "Cat core vaccine description for FVRCP."
  },
  "hgCatCoreRabies": "**Rabies** — required for outdoor cats and recommended for indoor cats as well (legally required)",
  "@hgCatCoreRabies": {
    "description": "Cat core vaccine description for rabies."
  },
  "hgCatNonCoreFelv": "**Feline Leukemia (FeLV)** — strongly recommended for outdoor cats and multi-cat households",
  "@hgCatNonCoreFelv": {
    "description": "Cat non-core vaccine description for FeLV."
  },
  "hgCatNonCoreChlamydia": "**Feline Chlamydia** — helps prevent conjunctivitis in multi-cat environments",
  "@hgCatNonCoreChlamydia": {
    "description": "Cat non-core vaccine description for chlamydia."
  },
  "hgCatNonCoreFiv": "**Feline Immunodeficiency Virus (FIV)** — especially relevant for outdoor male cats; transmitted through fight wounds",
  "@hgCatNonCoreFiv": {
    "description": "Cat non-core vaccine description for FIV."
  },

  "hgCatExternalParasites1": "Outdoor cats: administer flea and tick prevention **once a month**",
  "@hgCatExternalParasites1": {
    "description": "Cat external parasite prevention guidance item 1."
  },
  "hgCatExternalParasites2": "Even indoor cats can be exposed to fleas carried in on clothing or shoes → prevention **every 3 months** is recommended",
  "@hgCatExternalParasites2": {
    "description": "Cat external parasite prevention guidance item 2."
  },
  "hgCatExternalParasites3": "When using spot-on products, apply accurately to the back of the neck",
  "@hgCatExternalParasites3": {
    "description": "Cat external parasite prevention guidance item 3."
  },
  "hgCatInternalHeartworm": "Internal Parasites & Heartworm",
  "@hgCatInternalHeartworm": {
    "description": "Card title for cat internal parasites and heartworm."
  },
  "hgCatInternalParasites1": "Roundworms and tapeworms: administer dewormer **every 3–6 months**",
  "@hgCatInternalParasites1": {
    "description": "Cat internal parasite prevention guidance item 1."
  },
  "hgCatInternalParasites2": "If fed raw meat or raw fish, more frequent testing is recommended",
  "@hgCatInternalParasites2": {
    "description": "Cat internal parasite prevention guidance item 2."
  },
  "hgCatHeartworm1": "Heartworm — cats have **no curative treatment, so prevention is the only option**. Monthly prevention is strongly recommended for outdoor cats",
  "@hgCatHeartworm1": {
    "description": "Cat heartworm prevention warning."
  },

  "hgCatMajorDiseases": "Major Feline Diseases to Watch For",
  "@hgCatMajorDiseases": {
    "description": "Section title for major feline diseases."
  },
  "hgCatDiseaseAlert": "Cats tend to hide pain and illness, so symptoms often appear only after a condition has progressed. Regular checkups are especially important.",
  "@hgCatDiseaseAlert": {
    "description": "Alert text for major feline diseases section."
  },
  "hgCatDiseaseFlutd": "**Feline Lower Urinary Tract Disease (FLUTD)** — common in male cats. Inability to urinate is an immediate emergency",
  "@hgCatDiseaseFlutd": {
    "description": "Description of FLUTD in cats."
  },
  "hgCatDiseaseCkd": "**Chronic Kidney Disease (CKD)** — one of the leading causes of death in senior cats. Regular kidney screening is essential from age 7",
  "@hgCatDiseaseCkd": {
    "description": "Description of chronic kidney disease in cats."
  },
  "hgCatDiseaseDiabetes": "**Feline Diabetes** — higher risk in obese and senior cats. Watch for increased thirst and urination",
  "@hgCatDiseaseDiabetes": {
    "description": "Description of feline diabetes."
  },
  "hgCatDiseaseHyperthyroidism": "**Hyperthyroidism** — common in cats over 10 years old. Watch for weight loss, increased appetite, and hyperactivity",
  "@hgCatDiseaseHyperthyroidism": {
    "description": "Description of hyperthyroidism in cats."
  },
  "hgCatDiseaseStomatitis": "**Stomatitis** — very common in cats. Bad breath, drooling, or appetite loss should be checked",
  "@hgCatDiseaseStomatitis": {
    "description": "Description of stomatitis in cats."
  },
  "hgCatDiseaseFhv": "**Feline Herpesvirus (FHV-1)** — once infected, it remains latent for life. Stress can trigger recurrence with sneezing, eye discharge, and conjunctivitis",
  "@hgCatDiseaseFhv": {
    "description": "Description of feline herpesvirus."
  },

  "hgHydrationDiet": "Hydration & Diet Management",
  "@hgHydrationDiet": {
    "description": "Section title for cat hydration and diet."
  },
  "hgCatHydrationAlert": "Cats naturally drink little water and are vulnerable to urinary diseases. Encouraging water intake is very important.",
  "@hgCatHydrationAlert": {
    "description": "Alert text for cat hydration section."
  },
  "hgCatHydration1": "Wet food, such as cans or pouches, is recommended to help increase hydration",
  "@hgCatHydration1": {
    "description": "Cat hydration guidance item 1."
  },
  "hgCatHydration2": "Many cats prefer running water — a **water fountain** can be effective",
  "@hgCatHydration2": {
    "description": "Cat hydration guidance item 2."
  },
  "hgCatHydration3": "Place the water bowl away from the food bowl; wide, shallow bowls are often preferred",
  "@hgCatHydration3": {
    "description": "Cat hydration guidance item 3."
  },
  "hgCatHydration4": "Target water intake: about **40–60 ml** per kg of body weight per day",
  "@hgCatHydration4": {
    "description": "Cat hydration guidance item 4."
  },

  "hgCatForbiddenFoodAlert": "The foods below are toxic to cats. Even small amounts can be dangerous, so never feed them.",
  "@hgCatForbiddenFoodAlert": {
    "description": "Warning text for foods forbidden to cats."
  },
  "hgCatForbiddenOnion": "**Onions, garlic, and leeks** — destroy red blood cells and cause hemolytic anemia; cats are more sensitive than dogs",
  "@hgCatForbiddenOnion": {
    "description": "Cat forbidden food description for onions, garlic, and leeks."
  },
  "hgCatForbiddenGrape": "**Grapes and raisins** — can cause kidney failure",
  "@hgCatForbiddenGrape": {
    "description": "Cat forbidden food description for grapes and raisins."
  },
  "hgCatForbiddenChocolate": "**Chocolate and caffeine** — toxic to the heart and nervous system",
  "@hgCatForbiddenChocolate": {
    "description": "Cat forbidden food description for chocolate and caffeine."
  },
  "hgCatForbiddenRawFish": "**Raw fish when fed continuously** — may cause thiamine, vitamin B1, deficiency",
  "@hgCatForbiddenRawFish": {
    "description": "Cat forbidden food description for raw fish."
  },
  "hgCatForbiddenMilk": "**Milk and dairy products** — many adult cats are lactose intolerant and may develop diarrhea",
  "@hgCatForbiddenMilk": {
    "description": "Cat forbidden food description for milk and dairy products."
  },
  "hgCatForbiddenXylitolAlcohol": "**Xylitol and alcohol** — toxic to the liver and nervous system",
  "@hgCatForbiddenXylitolAlcohol": {
    "description": "Cat forbidden food description for xylitol and alcohol."
  },
  "hgCatForbiddenAvocado": "**Avocado** — contains persin and may cause vomiting and diarrhea",
  "@hgCatForbiddenAvocado": {
    "description": "Cat forbidden food description for avocado."
  },
  "hgCatForbiddenRawEggWhite": "**Raw egg whites** — avidin blocks biotin absorption and may cause skin and coat problems",
  "@hgCatForbiddenRawEggWhite": {
    "description": "Cat forbidden food description for raw egg whites."
  },

  "hgCatEmergency1": "**Unable to urinate or blood in urine** — urethral obstruction is an emergency, especially in male cats",
  "@hgCatEmergency1": {
    "description": "Cat emergency symptom item 1."
  },
  "hgCatEmergency2": "Complete loss of appetite for more than 24 hours, with risk of fatty liver disease",
  "@hgCatEmergency2": {
    "description": "Cat emergency symptom item 2."
  },
  "hgCatEmergency3": "**Open-mouth breathing** — never normal in cats and requires immediate emergency care",
  "@hgCatEmergency3": {
    "description": "Cat emergency symptom item 3."
  },
  "hgCatEmergency4": "Sudden hind leg paralysis or coldness, possible thromboembolism",
  "@hgCatEmergency4": {
    "description": "Cat emergency symptom item 4."
  },
  "hgCatEmergency5": "Seizures, convulsions, or loss of consciousness",
  "@hgCatEmergency5": {
    "description": "Cat emergency symptom item 5."
  },
  "hgCatEmergency6": "Pale gums or tongue, or yellow discoloration/jaundice",
  "@hgCatEmergency6": {
    "description": "Cat emergency symptom item 6."
  },
  "hgCatEmergency7": "Vomiting or diarrhea 3 or more times in one day, or blood in stool/vomit",
  "@hgCatEmergency7": {
    "description": "Cat emergency symptom item 7."
  },
  "hgCatEmergency8": "Visible trauma, fracture, or heavy bleeding",
  "@hgCatEmergency8": {
    "description": "Cat emergency symptom item 8."
  },

  "hgEnvironmentMentalHealth": "Environment & Mental Health",
  "@hgEnvironmentMentalHealth": {
    "description": "Section title for cat environment and mental health."
  },
  "hgIndoorEnvironment": "Indoor Environment Management",
  "@hgIndoorEnvironment": {
    "description": "Card title for indoor environment management."
  },
  "hgStressManagement": "Stress Management",
  "@hgStressManagement": {
    "description": "Card title for stress management."
  },
  "hgCatEnvironment1": "**Litter boxes**: number of cats + 1 or more, cleaned daily",
  "@hgCatEnvironment1": {
    "description": "Cat indoor environment guidance item 1."
  },
  "hgCatEnvironment2": "**Scratchers**: at least 2, combining vertical and horizontal types",
  "@hgCatEnvironment2": {
    "description": "Cat indoor environment guidance item 2."
  },
  "hgCatEnvironment3": "**High spaces**: provide cat towers, shelves, or vertical spaces to satisfy territorial instincts",
  "@hgCatEnvironment3": {
    "description": "Cat indoor environment guidance item 3."
  },
  "hgCatEnvironment4": "**Hiding places**: provide boxes, tunnels, or safe spaces where the cat can hide",
  "@hgCatEnvironment4": {
    "description": "Cat indoor environment guidance item 4."
  },
  "hgCatStress1": "Stress in cats is directly linked to lowered immunity, FLUTD, and feline herpesvirus recurrence",
  "@hgCatStress1": {
    "description": "Cat stress management guidance item 1."
  },
  "hgCatStress2": "During major environmental changes such as moving or a new family member, a pheromone diffuser such as Feliway may help",
  "@hgCatStress2": {
    "description": "Cat stress management guidance item 2."
  },
  "hgCatStress3": "Provide at least **10–15 minutes** of interactive toy play every day",
  "@hgCatStress3": {
