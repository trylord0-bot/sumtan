  "hgDogCoreDhppl": "**DHPPL (Combo Vaccine)** — Distemper, Hepatitis, Parvovirus, Parainfluenza, Leptospirosis.\n1st dose at 6-8 weeks, 3 doses at 3-4 week intervals, then annual boosters.",
  "@hgDogCoreDhppl": {
    "description": "Health guide: Dog DHPPL"
  },
  "hgDogCoreRabies": "**Rabies** — 1st dose after 3 months of age, then annually (Legally required in many areas).",
  "@hgDogCoreRabies": {
    "description": "Health guide: Dog Rabies"
  },
  "hgDogCoreCorona": "**Coronavirus** — Starts at 6-8 weeks, 2 doses at 3-4 week intervals, then annual boosters.",
  "@hgDogCoreCorona": {
    "description": "Health guide: Dog Corona"
  },
  "hgDogNonCoreKennel": "**Kennel Cough** — Recommended for multi-dog environments, grooming salons, or boarding. Nasal or injectable.",
  "@hgDogNonCoreKennel": {
    "description": "Health guide: Dog Kennel Cough"
  },
  "hgDogNonCoreFlu": "**Influenza** — If highly active outdoors or frequently in contact with other dogs.",
  "@hgDogNonCoreFlu": {
    "description": "Health guide: Dog Influenza"
  },
  "hgDogHeartworm1": "Recommended to administer preventative medication **once a month** around mosquito season (March-November).",
  "@hgDogHeartworm1": {
    "description": "Health guide: Dog Heartworm 1"
  },
  "hgDogHeartworm2": "Treatment is difficult and fatal if infected — **Prevention is the best method**.",
  "@hgDogHeartworm2": {
    "description": "Health guide: Dog Heartworm 2"
  },
  "hgDogHeartworm3": "Must test for infection and confirm negative before administering.",
  "@hgDogHeartworm3": {
    "description": "Health guide: Dog Heartworm 3"
  },
  "hgDogHeartworm4": "Year-round administration is safer (Recommended by vets).",
  "@hgDogHeartworm4": {
    "description": "Health guide: Dog Heartworm 4"
  },
  "hgDogExternalParasites1": "Administer spot-on or oral preventative **monthly**.",
  "@hgDogExternalParasites1": {
    "description": "Health guide: Dog External Parasites 1"
  },
  "hgDogExternalParasites2": "Must check for ticks in ears, between toes, and armpits after walks.",
  "@hgDogExternalParasites2": {
    "description": "Health guide: Dog External Parasites 2"
  },
  "hgDogExternalParasites3": "When removing ticks, use tweezers to pull straight out slowly (Do not twist).",
  "@hgDogExternalParasites3": {
    "description": "Health guide: Dog External Parasites 3"
  },
  "hgDogInternalParasites1": "Roundworms, hookworms, whipworms: Administer dewormer **every 3-6 months**.",
  "@hgDogInternalParasites1": {
    "description": "Health guide: Dog Internal Parasites 1"
  },
  "hgDogInternalParasites2": "Puppy stage (from 2 weeks): Deworm 4 times at 2-week intervals, then regular maintenance.",
  "@hgDogInternalParasites2": {
    "description": "Health guide: Dog Internal Parasites 2"
  },
  "hgDental1": "Daily brushing is ideal — Recommended at least **3 times a week**.",
  "@hgDental1": {
    "description": "Health guide: Dental 1"
  },
  "hgDental2": "Must use **pet-specific toothpaste** (Human toothpaste containing xylitol is strictly forbidden).",
  "@hgDental2": {
    "description": "Health guide: Dental 2"
  },
  "hgDental3": "If tartar is severe, scaling at the vet is required (Requires general anesthesia).",
  "@hgDental3": {
    "description": "Health guide: Dental 3"
  },
  "hgDental4": "Dental chews and tooth toys can be used as supplementary care.",
  "@hgDental4": {
    "description": "Health guide: Dental 4"
  },
  "hgDogForbiddenFoodAlert": "The following foods are toxic to dogs. Even small amounts can be dangerous, so never feed them.",
  "@hgDogForbiddenFoodAlert": {
    "description": "Health guide: Dog forbidden food alert"
  },
  "hgDogForbiddenGrape": "**Grapes/Raisins** — Causes kidney failure, even small amounts are fatal.",
  "@hgDogForbiddenGrape": {
    "description": "Health guide: Dog forbidden grape"
  },
  "hgDogForbiddenChocolate": "**Chocolate/Cacao** — Theobromine poisoning, heart failure, seizures.",
  "@hgDogForbiddenChocolate": {
    "description": "Health guide: Dog forbidden chocolate"
  },
  "hgDogForbiddenOnion": "**Onions/Garlic/Leeks** — Destroys red blood cells, hemolytic anemia.",
  "@hgDogForbiddenOnion": {
    "description": "Health guide: Dog forbidden onion"
  },
  "hgDogForbiddenXylitol": "**Xylitol** — Insulin hypersecretion, hypoglycemia, liver failure.",
  "@hgDogForbiddenXylitol": {
    "description": "Health guide: Dog forbidden xylitol"
  },
  "hgDogForbiddenMacadamia": "**Macadamia Nuts** — Muscle weakness, high fever, vomiting.",
  "@hgDogForbiddenMacadamia": {
    "description": "Health guide: Dog forbidden macadamia"
  },
  "hgDogForbiddenDoughAlcohol": "**Raw Dough/Alcohol** — Ethanol poisoning, hypoglycemia.",
  "@hgDogForbiddenDoughAlcohol": {
    "description": "Health guide: Dog forbidden dough/alcohol"
  },
  "hgDogForbiddenAvocado": "**Avocado** — Contains persin, causes vomiting and diarrhea.",
  "@hgDogForbiddenAvocado": {
    "description": "Health guide: Dog forbidden avocado"
  },
  "hgEmergencyAlert": "If the following symptoms appear, visit the vet immediately.",
  "@hgEmergencyAlert": {
    "description": "Health guide: Emergency alert"
  },
  "hgDogEmergency1": "Complete loss of appetite for more than 24 hours.",
  "@hgDogEmergency1": {
    "description": "Health guide: Dog emergency 1"
  },
  "hgDogEmergency2": "Vomiting/diarrhea repeated 3 or more times a day.",
  "@hgDogEmergency2": {
    "description": "Health guide: Dog emergency 2"
  },
  "hgDogEmergency3": "Abdominal distension/retching (Suspected gastric dilatation-volvulus).",
